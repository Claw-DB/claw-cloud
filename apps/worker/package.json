{
  "name": "@claw/worker",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ background workers for claw-cloud async processing",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.2",
    "@claw/db": "workspace:*",
    "@claw/common": "workspace:*",
    "@claw/mailer": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0",
    "rimraf": "^5.0.0"
  }
}
