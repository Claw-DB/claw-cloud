{
  "name": "@claw/api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS API gateway with billing and auth for claw-cloud",
  "scripts": {
    "build": "nest build",
    "dev": "set -a && . ../../.env && set +a && tsc-watch --project tsconfig.json --onSuccess \"tsx dist/apps/api/src/main.js\"",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@aws-sdk/client-s3": "^3.815.0",
    "@claw/common": "workspace:*",
    "@claw/db": "workspace:*",
    "@claw/mailer": "workspace:*",
    "@fastify/http-proxy": "^10.0.0",
    "@kubernetes/client-node": "^1.0.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@node-saml/node-saml": "^5.0.0",
    "@node-saml/passport-saml": "^5.0.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "csv-stringify": "^6.5.2",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.3",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "rimraf": "^5.0.0",
    "supertest": "^7.2.2",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
