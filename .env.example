# Database
DATABASE_URL=postgresql://clawcloud:clawcloud@localhost:5432/clawcloud
DIRECT_DATABASE_URL=postgresql://clawcloud:clawcloud@localhost:5432/clawcloud

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-refresh-32-chars
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-session-secret-at-least-32

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# OAuth (dev placeholders)
GITHUB_CLIENT_ID=dev-github-client-id
GITHUB_CLIENT_SECRET=dev-github-client-secret
GOOGLE_CLIENT_ID=dev-google-client-id
GOOGLE_CLIENT_SECRET=dev-google-client-secret
